rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /analytics/{docId} {
      allow read, write: if true;
    }

    match /plots/{plotId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "ravatreena83@gmail.com";
    }

    match /properties/{propId} {
      allow read: if resource.data.get('status', '') == 'approved' || 
                     (request.auth != null && request.auth.uid == resource.data.get('userId', '')) ||
                     (request.auth != null && request.auth.token.email == "ravatreena83@gmail.com");
                     
      allow create: if request.auth != null && (
        (request.auth.token.email == "ravatreena83@gmail.com") || 
        (request.resource.data.get('status', '') == 'pending' && request.resource.data.get('userId', '') == request.auth.uid)
      );
      
      allow update: if request.auth != null && request.auth.token.email == "ravatreena83@gmail.com";
      
      allow delete: if request.auth != null && (
        request.auth.token.email == "ravatreena83@gmail.com" || 
        resource.data.get('userId', '') == request.auth.uid
      );
    }
  }
}
