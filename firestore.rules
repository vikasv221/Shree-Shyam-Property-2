rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /analytics/{docId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.token.email == "vr6473680@gmail.com";
      allow create: if true;
      allow update: if true;
    }

    match /plots/{plotId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "vr6473680@gmail.com";
    }

    match /properties/{propId} {
      allow read: if resource.data.get('status', '') == 'approved' || 
                     (request.auth != null && request.auth.token.email == "vr6473680@gmail.com") ||
                     resource.data.get('userId', '') != '';
                     
      allow create: if (request.auth != null && request.auth.token.email == "vr6473680@gmail.com") || 
        (request.resource.data.get('status', '') == 'pending');
      
      allow update: if request.auth != null && request.auth.token.email == "vr6473680@gmail.com";
      
      allow delete: if (request.auth != null && request.auth.token.email == "vr6473680@gmail.com") || 
        (resource.data.get('userId', '') != '');
    }
  }
}
